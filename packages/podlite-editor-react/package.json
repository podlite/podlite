{
  "name": "@podlite/editor-react",
  "version": "0.0.44",
  "description": "Rich text editor React component for Podlite — syntax highlighting, live preview, CodeMirror 6",
  "main": "./src/index.tsx",
  "types": "lib/index.d.ts",
  "typings": "./lib/index.d.ts",
  "homepage": "https://podlite.org",
  "bugs": {
    "url": "https://github.com/podlite/podlite/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/podlite/podlite.git",
    "directory": "packages/podlite-editor-react"
  },
  "keywords": [
    "podlite",
    "editor",
    "react",
    "react-component",
    "rich-text-editor",
    "markdown-editor",
    "codemirror",
    "codemirror-6",
    "live-preview",
    "syntax-highlighting",
    "wysiwyg"
  ],
  "license": "MIT",
  "funding": {
    "type": "opencollective",
    "url": "https://opencollective.com/podlite"
  },
  "sideEffects": true,
  "files": [
    "lib",
    "esm",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "jest": {
    "preset": "ts-jest",
    "snapshotSerializers": [
      "jest-serializer-html"
    ]
  },
  "publishConfig": {
    "access": "public",
    "module": "./esm/index.js",
    "main": "lib/index.js",
    "types": "lib/index.d.ts"
  },
  "_exports_": {
    "./lib/podlite-vars.css": "./lib/podlite-vars.css",
    "./lib/editor.css": "./lib/Editor.css",
    "./index.css": "./lib/Editor.old.css",
    "./demo/Components": "./demo/Components",
    ".": {
      "import": "./esm/index.js",
      "types": "./lib/index.d.ts",
      "require": "./lib/index.js"
    },
    "./index": {
      "import": "./esm/index.js",
      "require": "./lib/index.js"
    }
  },
  "scripts": {
    "clean": "rm -rf dist lib tsconfig.tsbuildinfo esm",
    "build": "yarn g:build && yarn g:copy_assets",
    "test": "yarn g:jest  --passWithNoTests"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.18.6",
    "@codemirror/language": "^6.10.8",
    "@codemirror/view": "^6.36.2",
    "@lezer/highlight": "^1.2.1",
    "@uiw/codemirror-extensions-events": "^4.23.8",
    "@uiw/codemirror-themes": "^4.23.8",
    "@uiw/react-codemirror": "^4.23.8",
    "dom-to-image-more": "^3.7.2",
    "react-is": "^18.0.0",
    "shiki": "^3.21.0"
  },
  "peerDependencies": {
    "react": "^16.0.0 || ^17.0.0 || ^18",
    "react-dom": "^16.0.0 || ^17.0.0 || ^18"
  }
}
