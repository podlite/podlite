{
  "name": "podlite",
  "version": "0.0.50",
  "description": "Podlite markup language parser — Markdown-compatible, with native support for diagrams, formulas, and custom blocks",
  "homepage": "https://podlite.org",
  "repository": {
    "type": "git",
    "url": "https://github.com/podlite/podlite.git",
    "directory": "packages/core"
  },
  "main": "./src/index.ts",
  "funding": {
    "type": "opencollective",
    "url": "https://opencollective.com/podlite"
  },
  "scripts": {
    "test": "yarn g:jest --passWithNoTests",
    "build": "yarn g:build",
    "watch": "run-p -r watch:*",
    "watch:ts": "tsc -w --pretty",
    "watch:tests": "jest --watch -t \"test\""
  },
  "bin": "./bin/podlite.js",
  "files": [
    "bin",
    "lib",
    "esm",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "keywords": [
    "podlite",
    "parser",
    "markup-language",
    "markup",
    "markdown",
    "markdown-alternative",
    "lightweight-markup",
    "ast",
    "syntax-tree",
    "html",
    "document-parser",
    "renderer"
  ],
  "author": "Aliaksandr Zahatski",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/podlite/podlite/issues"
  },
  "dependencies": {
    "@podlite/diagram": "workspace:^",
    "@podlite/formula": "workspace:*",
    "@podlite/image": "workspace:^",
    "@podlite/markdown": "workspace:*",
    "@podlite/schema": "workspace:^",
    "@podlite/toc": "workspace:*",
    "nanoid": "3.1.30"
  },
  "devDependencies": {
    "@types/jest": "^26.0.21",
    "@types/node": "^17.0.7",
    "npm-run-all": "^4.1.5",
    "typescript": "4.5.5"
  },
  "peerDependencies": {
    "react": "^16.0.0 || ^17.0.0 || ^18",
    "react-dom": "^16.0.0 || ^17.0.0 || ^18"
  },
  "publishConfig": {
    "access": "public",
    "main": "lib/index.js",
    "types": "./lib/index.d.ts",
    "module": "./esm/index.js"
  }
}
