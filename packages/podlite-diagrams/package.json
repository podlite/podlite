    "module": "./esm/index.js"
  },
  "dependencies": {
    "@podlite/schema": "workspace:*",
    "mermaid": "8.12.1",
    "react-is": "^18.0.0"
  },
  "peerDependencies": {
    "mermaid": "*",
    "react": "^16.0.0 || ^17.0.0 || ^18",
    "react-dom": "^16.0.0 || ^17.0.0 || ^18",
    "react-is": "*"
  }
