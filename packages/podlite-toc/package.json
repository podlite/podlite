{
  "name": "@podlite/toc",
  "version": "0.0.31",
  "description": "Auto-generate table of contents from Podlite documents",
  "main": "./src/index.tsx",
  "homepage": "https://podlite.org",
  "bugs": {
    "url": "https://github.com/podlite/podlite/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/podlite/podlite.git",
    "directory": "packages/podlite-toc"
  },
  "license": "MIT",
  "funding": {
    "type": "opencollective",
    "url": "https://opencollective.com/podlite"
  },
  "scripts": {
    "clean": "rm -rf dist lib tsconfig.tsbuildinfo",
    "build": "yarn g:build",
    "test": "yarn g:jest  --passWithNoTests"
