  "peerDependencies": {
    "react": "^16.0.0 || ^17.0.0 || ^18",
    "react-dom": "^16.0.0 || ^17.0.0 || ^18"
  },
  "dependencies": {
    "@podlite/schema": "workspace:*",
    "react": "^16.0.0 || ^17.0.0 || ^18",
